        { "Host": "eventschedule", "Port": 8080 }
      ],
      "UpstreamPathTemplate": "/space/{spaceId}/events/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/space/{spaceId}/regularevent/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "eventschedule", "Port": 8080 }
      ],
      "UpstreamPathTemplate": "/space/{spaceId}/regular_events/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
