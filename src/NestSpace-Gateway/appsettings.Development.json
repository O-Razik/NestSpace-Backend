{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Ocelot": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "RabbitMQ",
        "Args": {
          "hostname": "localhost",
          "username": "guest",
          "password": "guest",
          "exchange": "logs_exchange",
          "exchangeType": "direct",
          "textFormatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithEnvironmentName" ]
  }
}